// PostgreSQL Prisma Schema
// Multi-file schema using schema imports
// This schema file contains generator and datasource configuration
// Individual models are organized in separate files under prisma/schema/

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
