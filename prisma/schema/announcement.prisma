// ============================================================================
// ANNOUNCEMENTS
// ============================================================================

model Announcement {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  type        Int       @default(1) // 0: WARNING, 1: INFO, 2: CONGRATULATION, 3: EMERGENCY
  content     String?   @db.Text
  imageFileID String?   @db.Uuid
  imageFile   File?     @relation(fields: [imageFileID], references: [id], onDelete: SetNull)
  start_date  DateTime?
  end_date    DateTime?
  scope       Int       @default(0) // 0: GLOBAL (only global scope available without departments)
  createdBy   String?   @db.Uuid
  status      Int       @default(1) // 1: ACTIVE, 0: PASSIVE
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([scope])
  @@index([status])
  @@index([start_date])
  @@index([deletedAt])
  @@map("announcements")
}
