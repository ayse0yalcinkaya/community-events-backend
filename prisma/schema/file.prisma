// ============================================================================
// FILE MANAGEMENT
// ============================================================================

model File {
  id           String    @id @default(uuid()) @db.Uuid
  userID       String    @db.Uuid
  filename     String
  originalName String
  mimeType     String
  size         Int
  s3Key        String
  s3Bucket     String
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  // Relations
  user        User  @relation(fields: [userID], references: [id])
  userProfile User? @relation("UserProfileImage")

  announcements Announcement[]
  // Chat Group Photo
  chatGroups    ChatGroup[]
  communityLogos       Community[] @relation("CommunityLogo")
  communityCoverImages Community[] @relation("CommunityCoverImage")
  eventCoverImages     Event[]     @relation("EventCoverImage")
  eventSpeakerPhotos   EventSpeaker[] @relation("EventSpeakerPhoto")
  eventSponsorLogos    EventSponsor[] @relation("EventSponsorLogo")
  eventGalleryFiles    EventGallery[] @relation("EventGallery")
  communityGalleryFiles CommunityGallery[] @relation("CommunityGallery")

  @@index([userID])
  @@index([s3Key])
  @@index([deletedAt])
  @@map("files")
}
