# Environment Variables Configuration
# Copy this file to .env and update with your actual values
# cp .env.example .env

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api
BASE_URL=http://localhost:3000
SWAGGER_ENABLED=true

# ============================================
# Database Configuration
# ============================================
# PostgreSQL example: postgresql://username:password@localhost:5432/dbname
# MongoDB example: mongodb://username:password@localhost:27017/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community_events

# PostgreSQL Docker Compose Service Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=community_events

# MongoDB Docker Compose Service Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password

# Optional: Database connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# JWT Configuration
# ============================================
# Generate secure secret: openssl rand -base64 32
JWT_SECRET=replace-with-a-secure-random-base64-string
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================
# AES Configuration for Password Hashing
# ============================================
# Generate secure key: openssl rand -hex 32 (64 hex characters for 32 bytes)
AES_SECRET_KEY=replace-with-a-64-character-hex-key

# ============================================
# AWS S3 Configuration (Epic 4: File Management)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET=community-events-files

# Optional: MinIO Local Development Configuration
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true

# ============================================
# FONIVA SMS Configuration (Epic 5: Communication Infrastructure)
# ============================================
SMS_PROVIDER=FONIVA
FONIVA_API_URL=https://api.foniva.com
FONIVA_USERNAME=your-foniva-username
FONIVA_PASSWORD=your-foniva-password
FONIVA_API_KEY=your-foniva-api-key
FONIVA_SENDER=YourSenderName

# ============================================
# Meta WhatsApp Cloud API Configuration
# ============================================
# Production OTP delivery is handled via WhatsApp Cloud API.
# Approved template body should accept one variable for OTP code: {{1}}
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0
WHATSAPP_ACCESS_TOKEN=your-meta-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-number-id
WHATSAPP_OTP_TEMPLATE_NAME=your_approved_otp_template_name
WHATSAPP_OTP_TEMPLATE_LANGUAGE_CODE=tr
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-a-random-verify-token

# ============================================
# SendGrid Email Configuration (Epic 5: Communication Infrastructure)
# ============================================
MAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
MAIL_FROM=noreply@example.com

# ============================================
# Redis Cache Configuration (Epic 6.5: Common Cache Service)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# Document Generator Cache & Retry Configuration (Story 6.5-3)
# ============================================
DOCUMENT_CACHE_TTL=3600000          # 1 hour (ms)
DOCUMENT_RETRY_MAX_ATTEMPTS=3       # Max retry attempts
DOCUMENT_RETRY_BASE_DELAY=1000      # Base delay (ms)

# ============================================
# S3 Service Retry Configuration (Story 6.5-4)
# ============================================
S3_RETRY_MAX_ATTEMPTS=5             # Max retry attempts for S3 operations
S3_RETRY_BASE_DELAY=2000            # Base delay (ms) for S3 operations

# ============================================
# Mail Service Retry Configuration (Story 6.5-5)
# ============================================
MAIL_RETRY_MAX_ATTEMPTS=5           # Max retry attempts (critical communication)
MAIL_RETRY_BASE_DELAY=2000          # Base delay (ms)

# ============================================
# SMS Service Retry Configuration (Story 6.5-5)
# ============================================
SMS_RETRY_MAX_ATTEMPTS=5            # Max retry attempts (critical communication)
SMS_RETRY_BASE_DELAY=2000           # Base delay (ms)

# ============================================
# Optional: Sentry Error Tracking (Epic 7.5)
# ============================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_DEBUG=false

# ============================================
# Optional: Logger Configuration (Epic 7.3)
# ============================================
# LOG_DIR=logs
# LOG_MAX_SIZE=20m
# LOG_MAX_FILES=14d
# LOG_LEVEL=debug
# ENABLE_FILE_LOGGING=false

# ============================================
# Chat Encryption Configuration
# ============================================
# Generate secure key: openssl rand -hex 32 (64 hex characters for 32 bytes)
# Used for AES-256-CBC encryption of chat messages at rest
CHAT_ENCRYPTION_KEY=replace-with-a-64-character-hex-key

# ============================================
# Optional: Firebase Push Notifications (Epic 5.8)
# ============================================
# FIREBASE_ENABLED=false
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_PRIVATE_KEY=your-firebase-private-key
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ============================================
# Firebase Service Retry Configuration (Story 6.5-6)
# ============================================
FIREBASE_RETRY_MAX_ATTEMPTS=5           # Max retry attempts (critical communication)
FIREBASE_RETRY_BASE_DELAY=2000          # Base delay (ms)
