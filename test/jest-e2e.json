{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["node_modules/(?!uuid)"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/../src/$1"
  },
  "globalSetup": "<rootDir>/jest-e2e-global-setup.ts",
  "setupFiles": ["<rootDir>/jest-e2e-setup.ts"],
  "maxWorkers": 4,
  "testTimeout": 30000
}
